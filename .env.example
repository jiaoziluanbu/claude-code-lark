APP_ID=cli_xxxxxx
APP_SECRET=xxxxxx

# ── 安全配置 ──
# 飞书 user_id 白名单（逗号分隔），为空则允许所有人
ALLOWED_USER_IDS=

# 自动放行的工具（无需授权），默认只读工具
AUTO_APPROVE_TOOLS=Read,Glob,Grep

# 授权等待超时（秒），超时自动拒绝
APPROVAL_TIMEOUT=120

# ── Agent 后端 ──
# claude 或 codex
DEFAULT_AGENT_BACKEND=claude

# Codex 默认模型
CODEX_DEFAULT_MODEL=gpt-5.3-codex

# Codex 默认工作目录；相对路径会优先从 CODEX_WORKSPACE_ROOTS 里解析
CODEX_DEFAULT_CWD=~/Documents/自制产品

# 允许远程切换/创建工作目录的 workspace 根目录（逗号分隔）
CODEX_WORKSPACE_ROOTS=~/Documents/自制产品,~

# 为了接近 Claude Code 的远程开发体验，默认给 Codex 全权限。
# 可在飞书里用 /sandbox read-only 或 /sandbox workspace-write 降级。
CODEX_DEFAULT_SANDBOX=danger-full-access

# Codex 单次任务超时时间（秒）
CODEX_TIMEOUT=1800
